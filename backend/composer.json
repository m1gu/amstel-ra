{
    "name": "amstel/backend-api",
    "description": "API REST para el ecosistema Amstel WebAR",
    "type": "project",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "slim/slim": "4.*",
        "slim/psr7": "^1.6",
        "firebase/php-jwt": "^5.5",
        "tuupola/slim-jwt-auth": "^3.7"
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "slim/slim": true
        }
    }
}