DirectoryIndex index.html index.php
Options -Indexes

RewriteEngine On
RewriteBase /vasodelahistoria/

# No tocar API ni WebAR
RewriteRule ^(api|webar)(/|$) - [L]

# Si existe archivo o carpeta real, servirlo normal
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback
RewriteRule ^ index.html [L]
